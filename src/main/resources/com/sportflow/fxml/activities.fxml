<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox fx:id="rootPane" prefHeight="600.0" prefWidth="1000.0" spacing="20.0" styleClass="dashboard-pane" stylesheets="@../css/style.css" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.sportflow.controller.ActivitiesController">
   <children>
      <HBox alignment="CENTER_LEFT">
         <children>
            <Button onAction="#handleBackToDashboard" style="-fx-background-color: transparent; -fx-text-fill: #A0A0A0; -fx-cursor: hand; -fx-font-size: 14px;" text="← Retour" />
            <Region HBox.hgrow="ALWAYS" />
            <VBox alignment="CENTER_RIGHT">
               <children>
                  <Label styleClass="header-title" text="🏃 Suivi des Activités" />
                  <Label style="-fx-text-fill: #A0A0A0;" text="Consultez l'historique de vos séances sportives." />
               </children>
            </VBox>
         </children>
         <padding>
            <Insets bottom="20.0" />
         </padding>
      </HBox>
      
      <TableView prefHeight="400.0" prefWidth="200.0" styleClass="card" VBox.vgrow="ALWAYS">
        <columns>
          <TableColumn prefWidth="150.0" text="Date" />
          <TableColumn prefWidth="200.0" text="Type" />
          <TableColumn prefWidth="150.0" text="Durée" />
          <TableColumn prefWidth="150.0" text="Distance" />
          <TableColumn prefWidth="150.0" text="Calories" />
        </columns>
      </TableView>
   </children>
   <padding>
      <Insets bottom="30.0" left="30.0" right="30.0" top="30.0" />
   </padding>
</VBox>
