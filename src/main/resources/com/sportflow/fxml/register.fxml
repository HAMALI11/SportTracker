<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<StackPane prefHeight="720.0" prefWidth="1280.0" stylesheets="@../css/style.css" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.sportflow.controller.RegisterController">
   <children>
      <VBox alignment="CENTER" maxWidth="450.0" spacing="20.0" styleClass="card" StackPane.alignment="CENTER">
         <children>
            <VBox alignment="CENTER" spacing="10.0">
               <children>
                  <Label style="-fx-font-size: 32px; -fx-font-weight: bold; -fx-text-fill: white;" text="CRÉER UN COMPTE" />
                  <Label style="-fx-text-fill: #A0A0A0; -fx-font-size: 14px;" text="Rejoignez la communauté SportFlow dès aujourd'hui" />
               </children>
            </VBox>

            <VBox spacing="12.0">
               <children>
                  <VBox spacing="5.0">
                     <Label style="-fx-text-fill: white;" text="Nom complet" />
                     <TextField fx:id="fullNameField" promptText="Jean Dupont" styleClass="text-input" />
                  </VBox>

                  <VBox spacing="5.0">
                     <Label style="-fx-text-fill: white;" text="Nom d'utilisateur" />
                     <TextField fx:id="usernameField" promptText="hamali" styleClass="text-input" />
                  </VBox>

                  <VBox spacing="5.0">
                     <Label style="-fx-text-fill: white;" text="Email" />
                     <TextField fx:id="emailField" promptText="exemple@email.com" styleClass="text-input" />
                  </VBox>

                  <VBox spacing="5.0">
                     <Label style="-fx-text-fill: white;" text="Mot de passe" />
                     <PasswordField fx:id="passwordField" promptText="••••••••" styleClass="text-input" />
                  </VBox>

                  <VBox spacing="5.0">
                     <Label style="-fx-text-fill: white;" text="Confirmer le mot de passe" />
                     <PasswordField fx:id="confirmPasswordField" promptText="••••••••" styleClass="text-input" />
                  </VBox>
               </children>
            </VBox>

            <VBox spacing="10.0">
               <children>
                  <Button maxWidth="Infinity" mnemonicParsing="false" onAction="#handleCreateAccount" styleClass="primary-button" text="Créer mon compte" />
                  <Label fx:id="errorLabel" alignment="CENTER" maxWidth="Infinity" style="-fx-font-size: 12px;" text="" wrapText="true" />
               </children>
            </VBox>

            <HBox alignment="CENTER" spacing="5.0">
               <children>
                  <Label style="-fx-text-fill: #666666;" text="Déjà un compte ?" />
                  <Label onMouseClicked="#handleBackToLogin" style="-fx-text-fill: #00A3FF; -fx-cursor: hand;" text="Se connecter" />
               </children>
            </HBox>
         </children>
         <padding>
            <Insets bottom="40.0" left="40.0" right="40.0" top="40.0" />
         </padding>
      </VBox>
   </children>
</StackPane>
