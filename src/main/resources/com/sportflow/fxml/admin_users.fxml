<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox fx:id="rootPane" prefHeight="720.0" prefWidth="1280.0" spacing="20.0" styleClass="dashboard-pane" stylesheets="@../css/style.css" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.sportflow.controller.AdminController">
   <children>
      <!-- Header Admin -->
      <HBox alignment="CENTER_LEFT" spacing="20.0" style="-fx-background-color: #1A1A1A; -fx-padding: 20;">
         <children>
            <VBox>
               <children>
                  <Label style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #FFBD00;" text="⚙️ Administration" />
                  <Label style="-fx-text-fill: #A0A0A0;" text="Gestion des utilisateurs de la plateforme" />
               </children>
            </VBox>
            <Region HBox.hgrow="ALWAYS" />
            <Button onAction="#handleLogout" style="-fx-background-color: #FF4B2B; -fx-text-fill: white;" text="Déconnexion" />
         </children>
      </HBox>

      <!-- Main Content -->
      <VBox spacing="15.0" VBox.vgrow="ALWAYS">
         <children>
            <Label styleClass="card-title" text="LISTE DES UTILISATEURS ENREGISTRÉS" />
            <TableView fx:id="usersTable" prefHeight="400.0" styleClass="card" VBox.vgrow="ALWAYS">
              <columns>
                <TableColumn fx:id="colId" prefWidth="100.0" text="ID" />
                <TableColumn fx:id="colUsername" prefWidth="250.0" text="Nom d'utilisateur" />
                <TableColumn fx:id="colEmail" prefWidth="350.0" text="E-mail" />
                <TableColumn fx:id="colDate" prefWidth="250.0" text="Date d'inscription" />
              </columns>
            </TableView>
            <HBox alignment="CENTER_RIGHT" spacing="10.0">
               <children>
                  <Button onAction="#refreshTable" text="RAFRAÎCHIR" styleClass="primary-button" />
               </children>
            </HBox>
         </children>
         <padding>
            <Insets bottom="30.0" left="30.0" right="30.0" top="30.0" />
         </padding>
      </VBox>
   </children>
</VBox>
