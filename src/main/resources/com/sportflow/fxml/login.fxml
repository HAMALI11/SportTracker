<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.text.Text?>

<StackPane prefHeight="720.0" prefWidth="1280.0" stylesheets="@../css/style.css" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.sportflow.controller.LoginController">
   <children>
      <VBox alignment="CENTER" maxWidth="400.0" spacing="30.0" styleClass="card" StackPane.alignment="CENTER">
         <children>
            <VBox alignment="CENTER" spacing="10.0">
               <children>
                  <Label style="-fx-font-size: 32px; -fx-font-weight: bold; -fx-text-fill: white;" text="⚡ SPORTFLOW" />
                  <Label style="-fx-text-fill: #A0A0A0; -fx-font-size: 14px;" text="Veuillez vous connecter pour accéder à vos données" />
               </children>
            </VBox>
            
            <VBox spacing="15.0">
               <children>
                  <VBox spacing="5.0">
                     <children>
                        <Label style="-fx-text-fill: white;" text="Utilisateur" />
                        <TextField fx:id="usernameField" promptText="Nom d'utilisateur" styleClass="text-input" />
                     </children>
                  </VBox>
                  
                  <VBox spacing="5.0">
                     <children>
                        <Label style="-fx-text-fill: white;" text="Mot de passe" />
                        <PasswordField fx:id="passwordField" promptText="••••••••" styleClass="text-input" />
                     </children>
                  </VBox>
               </children>
            </VBox>
            
            <VBox spacing="15.0">
               <children>
                  <Button fx:id="loginButton" maxWidth="Infinity" mnemonicParsing="false" onAction="#handleLogin" styleClass="primary-button" text="Se Connecter" />
                  <Label fx:id="errorLabel" alignment="CENTER" maxWidth="Infinity" style="-fx-text-fill: #FF4B2B; -fx-font-size: 12px;" text="" />
               </children>
            </VBox>
            
            <HBox alignment="CENTER" spacing="5.0">
               <children>
                  <Label style="-fx-text-fill: #666666;" text="Pas encore de compte ?" />
                  <Label style="-fx-text-fill: #00A3FF; -fx-cursor: hand;" text="S'inscrire" />
               </children>
            </HBox>
         </children>
         <padding>
            <Insets bottom="40.0" left="40.0" right="40.0" top="40.0" />
         </padding>
      </VBox>
   </children>
</StackPane>
