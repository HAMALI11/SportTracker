<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<StackPane prefHeight="720.0" prefWidth="1280.0" stylesheets="@../css/style.css" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.sportflow.controller.LoginController">
   <children>
      <VBox alignment="CENTER" maxWidth="500.0" spacing="30.0" styleClass="card" StackPane.alignment="CENTER">
         <children>
            <VBox alignment="CENTER" spacing="15.0">
               <children>
                  <Label style="-fx-font-size: 48px;" text="⚠️" />
                  <Label style="-fx-font-size: 28px; -fx-font-weight: bold; -fx-text-fill: #FF4B2B;" text="ACCÈS BLOQUÉ" />
                  <Label style="-fx-text-fill: white; -fx-font-size: 16px; -fx-text-alignment: center;" text="Vous avez saisi 3 mots de passe incorrects.&#10;Par mesure de sécurité, votre accès est temporairement suspendu." wrapText="true" />
               </children>
            </VBox>
            
            <VBox alignment="CENTER" spacing="10.0" style="-fx-background-color: #2D2D2D; -fx-padding: 20px; -fx-background-radius: 10px;">
               <children>
                  <Label style="-fx-text-fill: #A0A0A0;" text="Veuillez contacter le support administratif pour" />
                  <Label style="-fx-text-fill: white; -fx-font-weight: bold;" text="réinitialiser votre accès." />
                  <Label style="-fx-text-fill: #00A3FF;" text="support@sportflow.com" />
               </children>
            </VBox>
            
            <Button onAction="#handleBackToLoginFromLocked" styleClass="primary-button" text="Retour à l'accueil" />
         </children>
         <padding>
            <Insets bottom="50.0" left="50.0" right="50.0" top="50.0" />
         </padding>
      </VBox>
   </children>
</StackPane>
